# Paste all of these into Vercel → Project → Settings → Environment Variables

# Locally report URL (the full URL George gave you)
LOCALLY_API_URL=https://www.locally.com/api/v2/reports/json/e93fec70-1934-4652-a96b-f820646cbdbb/24070/0

# From locally.com → Administrative → API & FTP Credentials → Show button
LOCALLY_API_TOKEN=your_locally_api_token

# Your Shopify store
SHOPIFY_STORE=westridge-outdoors.myshopify.com

# From dev.shopify.com → Locally Sync app → Settings
# Client ID (visible on the page)
SHOPIFY_CLIENT_ID=f1aae2f4d39b107e193b7e8541a255f0

# Client Secret (click the eye icon on the Settings page to reveal)
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# Make up any random password — paste same value into Shopify Flow header X-Sync-Secret
SYNC_SECRET=retrospec2026secret
